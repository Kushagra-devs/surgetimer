DATABASE_URL="postgresql://postgres:postgres@postgres:5432/horse_timer"
REDIS_URL="redis://redis:6379"
JWT_SECRET="change-me"
REFRESH_TOKEN_SECRET="change-me-too"
API_PORT=4000
WEB_PORT=3000
NODE_ENV="development"
HARDWARE_ADAPTER_MODE="mock"
HARDWARE_SERIAL_PORT="/dev/ttyUSB0"
HARDWARE_TCP_HOST="127.0.0.1"
HARDWARE_TCP_PORT=2000
SENSOR_DEBOUNCE_MS=250
WARMUP_DURATION_SEC=45
MAX_ROUND_DURATION_SEC=300
TIMER_MODE="SEQUENTIAL_GENERIC"
START_SENSOR="C0"
MAIN_START_SENSOR="C1"
FINISH_SENSOR="C2"

