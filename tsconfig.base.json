{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@horse-timer/types": [
        "packages/types/src"
      ],
      "@horse-timer/timer-engine": [
        "packages/timer-engine/src"
      ],
      "@horse-timer/hardware-adapters": [
        "packages/hardware-adapters/src"
      ]
    }
  }
}

